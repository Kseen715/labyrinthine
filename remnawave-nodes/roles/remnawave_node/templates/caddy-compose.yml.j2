services:
  caddy:
    image: caddy:latest
    container_name: caddy
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - ./templates:/srv/templates:ro
      - /var/lib/remnawave/caddy/certificates:/data/caddy/certificates
      - /var/lib/remnawave/caddy/config:/config/caddy
